class BSTIterator {
    TreeNode root;
    Queue<Integer> q = new LinkedList();

    public BSTIterator(TreeNode root) {
        this.root = root;
        helper(root);
        
    }

    public int next() {
        return q.poll();
    }

    public boolean hasNext() {
        return !q.isEmpty();
    }

    private void helper(TreeNode root) {
        if (root == null)
            return ;
        helper(root.left);
        q.add(root.val);
        helper(root.right);

    }
}

